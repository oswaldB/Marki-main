# ============================================
# Global ignore pour le monorepo marki/
# ============================================

# --- OS / éditeur ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# --- Node.js / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak
.npm/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
venv/
.venv/
env/
.env
.env.local
*.pyc

# --- Bases de données / fichiers binaires ---
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --- Logs ---
*.log
logs/
npm-debug.log*

# --- Build / artefacts ---
dist/
build/
out/
*.tsbuildinfo
.next/
.nuxt/
.cache/
coverage/

# --- OS / divers ---
*.bak
*.tmp
*.swp
.DS_Store

# --- Secrets (par sécurité) ---
*.pem
*.key
secrets/
credentials/
