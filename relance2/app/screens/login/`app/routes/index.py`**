"""Routes principales de l'application."""

from flask import Blueprint, render_template, request, jsonify
from app.models.auth import AuthModel, AuthError

index_bp = Blueprint('index', __name__)


@index_bp.route('/')
def login_page():
    """Page de login."""
    return render_template('login.html')


@index_bp.route('/dashboard')
def dashboard():
    """Page dashboard (protégée)."""
    # Vérification du token via header ou query param
    token = request.headers.get('Authorization', '').replace('Bearer ', '')
    if not token:
        token = request.args.get('token', '')
    
    try:
        if token:
            user = AuthModel.verify_token(token)
            return render_template('dashboard.html', user=user.to_dict())
    except AuthError:
        pass
    
    # Si pas de token valide, render quand même mais Alpine vérifiera
    return render_template('dashboard.html')