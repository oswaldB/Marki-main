"""Routes API pour l'authentification."""

from flask import Blueprint, request, jsonify
from app.models.auth import AuthModel, AuthError

api_auth_bp = Blueprint('api_auth', __name__)


@api_auth_bp.route('/login', methods=['POST'])
def login():
    """
    Authentifie un utilisateur et retourne un token JWT.
    
    Body JSON: {email: string, password: string} ou {username: string, password: string}
    """
    data = request.get_json()
    
    if not data:
        return jsonify({'error': 'Données manquantes'}), 400
    
    email = data.get('email')
    username = data.get('username')
    password = data.get('password')
    
    if not password:
        return jsonify({'error': 'Mot de passe requis'}), 400
    
    if not email and not username:
        return jsonify({'error': 'Email ou username requis'}), 400
    
    try:
        if email:
            result = AuthModel.authenticate_by_email(email, password)
        else:
            result = AuthModel.authenticate(username, password)
        
        return jsonify({
            'token': result['token'],
            'user': result['user'].to_dict()
        }), 200
        
    except AuthError as e:
        return jsonify({'error': str(e)}), 401


@api_auth_bp.route('/me', methods=['GET'])
def me():
    """
    Retourne l'utilisateur connecté à partir du token JWT.
    Header: Authorization: Bearer <token>
    """
    auth_header = request.headers.get('Authorization', '')
    token = auth_header.replace('Bearer ', '') if auth_header.startswith('Bearer ') else None
    
    if not token:
        return jsonify({'error': 'Token manquant'}), 401
    
    try:
        user = AuthModel.verify_token(token)
        return jsonify({'user': user.to_dict()}), 200
        
    except AuthError as e:
        return jsonify({'error': str(e)}), 401