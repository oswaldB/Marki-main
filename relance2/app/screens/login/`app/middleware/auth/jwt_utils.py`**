"""JWT utilities pour l'authentification."""

import jwt
from datetime import datetime, timedelta
from flask import current_app


def generate_token(user_id, username, role, expires_in=24):
    """
    Génère un token JWT.
    
    Args:
        user_id: ID de l'utilisateur
        username: Nom d'utilisateur
        role: Rôle de l'utilisateur
        expires_in: Durée de validité en heures (défaut: 24)
    
    Returns:
        str: Token JWT encodé
    """
    payload = {
        'id': user_id,
        'username': username,
        'role': role,
        'exp': datetime.utcnow() + timedelta(hours=expires_in),
        'iat': datetime.utcnow()
    }
    
    secret = current_app.config.get('JWT_SECRET_KEY', current_app.config.get('SECRET_KEY'))
    return jwt.encode(payload, secret, algorithm='HS256')


def validate_token(token):
    """
    Valide et décode un token JWT.
    
    Args:
        token: Token JWT à valider
    
    Returns:
        dict: Payload du token si valide
    
    Raises:
        jwt.ExpiredSignatureError: Si le token est expiré
        jwt.InvalidTokenError: Si le token est invalide
    """
    secret = current_app.config.get('JWT_SECRET_KEY', current_app.config.get('SECRET_KEY'))
    return jwt.decode(token, secret, algorithms=['HS256'])