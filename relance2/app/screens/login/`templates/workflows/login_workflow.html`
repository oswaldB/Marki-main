{# 
    Workflow Frontend: Login
    Ce template est inclus dans login.html et fournit les composants workflow réutilisables
#}

{% macro login_form() %}
<!-- 
    Composant Formulaire de Login
    Usage: {{ login_form() }} dans un template Jinja2
-->
<div x-data="{ form: { email: '', password: '' }, loading: false, error: null }" 
     @submit.prevent="handleSubmit"
     class="space-y-6">
    
    <template x-if="error">
        <div class="rounded-md bg-red-50 p-4 mb-4" x-transition>
            <div class="flex">
                <div class="ml-3">
                    <p x-text="error" class="text-sm text-red-700"></p>
                </div>
            </div>
        </div>
    </template>
    
    <div>
        <label class="block text-sm font-medium text-gray-700">Email</label>
        <input 
            x-model="form.email"
            type="email"
            required
            class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3"
        >
    </div>
    
    <div>
        <label class="block text-sm font-medium text-gray-700">Mot de passe</label>
        <input 
            x-model="form.password"
            type="password"
            required
            class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3"
        >
    </div>
    
    <button 
        type="submit"
        :disabled="loading"
        class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700"
    >
        <span x-show="!loading">Se connecter</span>
        <span x-show="loading">Connexion...</span>
    </button>
</div>
{% endmacro %}


{% macro loading_spinner(size='md', text=null) %}
<!-- 
    Composant Spinner de Chargement
    Usage: {{ loading_spinner(size='lg', text='Chargement...') }}
-->
{% set sizes = {'sm': 'h-4 w-4', 'md': 'h-8 w-8', 'lg': 'h-12 w-12'} %}
<div class="flex flex-col items-center justify-center">
    <div class="animate-spin rounded-full border-b-2 border-primary-600 {{ sizes.get(size, sizes['md']) }}"></div>
    {% if text %}
    <p class="mt-2 text-sm text-gray-600">{{ text }}</p>
    {% endif %}
</div>
{% endmacro %}


{% macro error_message(message='Une erreur est survenue') %}
<!-- 
    Composant Message d'Erreur
    Usage: {{ error_message('Message personnalisé') }}
-->
<div class="rounded-md bg-red-50 p-4">
    <div class="flex">
        <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
        </div>
        <div class="ml-3">
            <p class="text-sm text-red-700">{{ message }}</p>
        </div>
    </div>
</div>
{% endmacro %}


{# 
    Scripts Workflow Login
    À inclure avec {% include 'workflows/login_workflow.html' %} 
    et appeler loginWorkflowInit()
#}
<script>
/**
 * Workflow Login - Fonctions utilitaires
 */
window.LoginWorkflow = {
    
    /**
     * @action Valider le format d'un email
     * @param {string} email - Email à valider
     * @returns {boolean} - True si valide
     */
    validateEmail(email) {
        const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return regex.test(email);
    },
    
    /**
     * @action Soumettre les identifiants à l'API
     * @param {string} email 
     * @param {string} password
     * @returns {Promise<Object>} - Données de réponse
     */
    async authSubmit(email, password) {
        const response = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify({ email, password })
        });
        
        if (!response.ok) {
            const error = await response.json();
            throw new Error(error.error || 'Échec de connexion');
        }
        
        return await response.json();
    },
    
    /**
     * @action Vérifier la session utilisateur
     * @returns {Promise<Object|null>} - User data ou null
     */
    async checkSession() {
        const token = localStorage.getItem('token');
        if (!token) return null;
        
        try {
            const response = await fetch('/api/auth/me', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            
            if (response.ok) {
                const data = await response.json();
                return data.user;
            }
        } catch (error) {
            console.error('Session check failed:', error);
        }
        
        localStorage.removeItem('token');
        return null;
    },
    
    /**
     * @action Stocker les données d'authentification
     * @param {string} token 
     * @param {Object} user 
     */
    storeAuth(token, user) {
        localStorage.setItem('token', token);
        if (window.Alpine) {
            Alpine.store('auth').token = token;
            Alpine.store('auth').user = user;
            Alpine.store('auth').isAuthenticated = true;
        }
    },
    
    /**
     * @action Rediriger vers le dashboard
     */
    redirectToDashboard() {
        window.location.href = '/dashboard';
    },
    
    /**
     * @action Nettoyer les données d'authentification
     */
    clearAuth() {
        localStorage.removeItem('token');
        if (window.Alpine) {
            Alpine.store('auth').token = null;
            Alpine.store('auth').user = null;
            Alpine.store('auth').isAuthenticated = false;
        }
    }
};
</script>